# Supabase — banco intermediário (dados agregados para o dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Service role — usado apenas no ETL (nunca expor no frontend)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# SQL Server — produção TCE-AC (usado apenas no ETL)
SQLSERVER_HOST=seu_servidor
SQLSERVER_DATABASE=seu_banco
SQLSERVER_USER=seu_usuario
SQLSERVER_PASSWORD=sua_senha
SQLSERVER_PORT=1433

# CSVs das dimensoes auxiliares (ETL)
DIM_UF_CSV=etl/data/dimensoes/dim_uf.csv
DIM_MUNICIPIO_CSV=etl/data/dimensoes/dim_municipios.csv
DIM_ENTE_CSV=etl/data/dimensoes/dim_ente.csv
DIM_ENTIDADE_CSV=etl/data/dimensoes/dim_entidade.csv
DIM_AUTO_BOOTSTRAP_FROM_SUPABASE=true

# Agendamento ETL noturno (pipeline unico, 1x ao dia)
ETL_TIMEZONE=America/Rio_Branco
FACT_ETL_CRON=0 1 * * *
RUN_DIMENSOES_NIGHTLY=true
