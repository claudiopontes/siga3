# =============================================================================
# Varadouro Digital Aquiry — variáveis de ambiente (frontend Next.js + ETL)
# =============================================================================
# Copie este arquivo para `.env.local` e preencha os valores.
# Variáveis marcadas como (ETL) são consumidas apenas pelos jobs em `etl/`.

# -----------------------------------------------------------------------------
# PostgreSQL — banco principal lido pelo frontend (read-only via src/lib/db.ts)
# -----------------------------------------------------------------------------
# Use DATABASE_URL OU as variáveis PG* individuais (DATABASE_URL tem prioridade).
DATABASE_URL=postgres://varadouro:varadouro@localhost:5432/varadouro_digital
PGHOST=localhost
PGPORT=5432
PGDATABASE=varadouro_digital
PGUSER=varadouro
PGPASSWORD=varadouro

# -----------------------------------------------------------------------------
# Azure OpenAI — usado pelo Assistente Aquiry e pelas análises IA de processo/pauta
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://SEU_RECURSO.openai.azure.com
AZURE_OPENAI_KEY=sua_chave_azure_openai
AZURE_OPENAI_DEPLOYMENT=nome_do_deployment
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# -----------------------------------------------------------------------------
# Autenticação Active Directory (Windows AD)
# -----------------------------------------------------------------------------
AD_LDAP_URL=ldap://172.20.12.86:389
AD_DOMAIN_PREFIX=tceac
# Opcional. Se vazio, o sistema tenta descobrir via RootDSE do AD.
AD_BASE_DN=
AD_DEBUG_GROUPS=false
AD_LDAP_CONNECT_TIMEOUT_MS=5000
AD_LDAP_TIMEOUT_MS=8000
AUTH_SESSION_SECRET=troque_por_uma_chave_longa_e_aleatoria
AUTH_USERS_TABLE=usuarios_autorizados

# -----------------------------------------------------------------------------
# Servidor de arquivos PDF do eProcess (Apache porta 8090)
# -----------------------------------------------------------------------------
REPOSITORIO_BASE_URL=http://172.20.12.105:8090

# -----------------------------------------------------------------------------
# SICONFI (Tesouro Nacional) — opcional, valores default já cobrem o uso normal
# -----------------------------------------------------------------------------
SICONFI_API_BASE_URL=https://apidatalake.tesouro.gov.br/ords/siconfi/tt
SICONFI_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Assistente Aquiry — busca externa controlada (opcional)
# -----------------------------------------------------------------------------
# Providers suportados: tavily | brave | serpapi | gemini
# Quando vazio ou ausente, o Aquiry mantém o fallback "Busca externa necessária".
AQUIRY_EXTERNAL_SEARCH_PROVIDER=
AQUIRY_EXTERNAL_SEARCH_API_KEY=
# Endpoint customizado opcional (usado por Tavily/Brave/SerpAPI/Gemini).
AQUIRY_EXTERNAL_SEARCH_ENDPOINT=

# Gemini (Google Generative Language API) — usado quando provider=gemini.
# Possui Grounding with Google Search ativado automaticamente.
AQUIRY_GEMINI_API_KEY=
AQUIRY_GEMINI_MODEL=gemini-2.5-flash
# Timeout em milissegundos para a chamada Gemini (default 20000, faixa 5000–60000).
# Grounding with Google Search costuma demorar 5–15 s.
AQUIRY_GEMINI_TIMEOUT_MS=20000

# Auditoria do Assistente Aquiry: persistência opcional dos eventos.
# Quando "true", grava metadados em public.aquiry_evento_uso (migration 260).
# Quando "false" ou ausente, mantém apenas console.info "[Aquiry][audit]".
# Nenhum conteúdo de pergunta/resposta/fontes/documentos é armazenado.
AQUIRY_AUDIT_PERSIST=false

# =============================================================================
# A partir daqui: variáveis usadas APENAS pelo ETL (etl/)
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — destino legado de duas tabelas que ainda têm sync (APC Polanco e
# receita-publica). O frontend NÃO lê mais Supabase.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
# Service role — usado apenas no ETL (nunca expor no frontend)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# -----------------------------------------------------------------------------
# SQL Server — fonte operacional (TCE-AC). Usado apenas no ETL.
# -----------------------------------------------------------------------------
SQLSERVER_HOST=seu_servidor
SQLSERVER_DATABASE=seu_banco
SQLSERVER_USER=seu_usuario
SQLSERVER_PASSWORD=sua_senha
SQLSERVER_PORT=1433

# CSVs das dimensoes auxiliares (ETL)
DIM_UF_CSV=etl/data/dimensoes/dim_uf.csv
DIM_MUNICIPIO_CSV=etl/data/dimensoes/dim_municipios.csv
DIM_ENTE_CSV=etl/data/dimensoes/dim_ente.csv
DIM_ENTIDADE_CSV=etl/data/dimensoes/dim_entidade.csv
DIM_AUTO_BOOTSTRAP_FROM_SUPABASE=true

# Agendamento ETL noturno (pipeline unico, 1x ao dia)
ETL_TIMEZONE=America/Rio_Branco
FACT_ETL_CRON=0 1 * * *
RUN_APC_POLANCO_NIGHTLY=true
RUN_APC_POLANCO_SUPABASE_SYNC_NIGHTLY=true
RUN_DIMENSOES_NIGHTLY=true
RUN_RECEITA_PUBLICA_NIGHTLY=true

# APC - carga Polanco (SQL Server)
SQLSERVER_APC_DATABASE=APC
APC_POLANCO_PROC_NAME=dbo.sp_carga_tb_despesa_combustivel_polanco
APC_POLANCO_MODO_CARGA=INCREMENTAL
APC_POLANCO_DIAS_REPROCESSAMENTO=90
APC_POLANCO_SUPABASE_TABLE=tb_despesa_combustivel_polanco
APC_POLANCO_SYNC_SQL_PAGE_SIZE=2000
APC_POLANCO_SYNC_SUPABASE_BATCH=500

# Receita Publica (SQL Server -> Supabase)
RECEITA_PUBLICA_SQLSERVER_DATABASE=APC
RECEITA_PUBLICA_SOURCE_VIEW=audit.vw_ReceitaPorCategoria
RECEITA_PUBLICA_SUPABASE_TABLE=receita_publica_categoria_mensal
RECEITA_PUBLICA_MODO_CARGA=INCREMENTAL
RECEITA_PUBLICA_LOOKBACK_MESES=3
RECEITA_PUBLICA_ANO_INICIO=
RECEITA_PUBLICA_SUPABASE_BATCH=500
