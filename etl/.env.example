# Supabase — banco intermediário
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# SQL Server — produção TCE-AC (autenticação Windows)
# Banco DFE: contém vw_NF_combustiveis, ENTIDADE e NOTA_FISCAL_CARGA
SQLSERVER_HOST=172.20.12.219
SQLSERVER_DATABASE=DFE
SQLSERVER_PORT=1433

# -------------------------------------------------------
# Destino do ETL
# -------------------------------------------------------
ETL_TARGET=postgres

# PostgreSQL local/desenvolvimento
DATABASE_URL=postgres://varadouro:varadouro_dev@localhost:5432/varadouro_digital
# Ou, separadamente:
PGHOST=localhost
PGPORT=5432
PGDATABASE=varadouro_digital
PGUSER=varadouro
PGPASSWORD=varadouro_dev
PGSSLMODE=disable

# Migração Supabase -> Postgres local
MIGRAR_TABELAS=dim_ente,dim_credor,fato_empenho
MIGRAR_MODO=truncate_insert
MIGRAR_BATCH_SIZE=1000

# -------------------------------------------------------
# Enriquecimento cadastral de credores — fonte interna SQL Server
# Execute: npm run credor:fontes:inspecionar  para descobrir os valores corretos.
# -------------------------------------------------------
CREDOR_INTERNO_DATABASE=APC
CREDOR_INTERNO_TABLE=
CREDOR_INTERNO_DOCUMENTO_COLUMN=
CREDOR_INTERNO_NOME_COLUMN=
CREDOR_INTERNO_TIPO_DOCUMENTO_COLUMN=
CREDOR_INTERNO_CIDADE_COLUMN=
CREDOR_INTERNO_UF_COLUMN=
CREDOR_INTERNO_EMAIL_COLUMN=
CREDOR_INTERNO_TELEFONE_COLUMN=

# -------------------------------------------------------
# Enriquecimento de CNPJ via API pública (opcional)
# CNPJ_ENRICH_PROVIDER: none | brasilapi | receitaws
# none = desativado (padrão seguro)
# -------------------------------------------------------
CNPJ_ENRICH_PROVIDER=none
CNPJ_ENRICH_RATE_LIMIT_MS=1000
CNPJ_ENRICH_MAX_PER_RUN=100
