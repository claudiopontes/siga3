# Supabase — banco intermediário
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# SQL Server — produção TCE-AC (autenticação Windows)
# Banco DFE: contém vw_NF_combustiveis, ENTIDADE e NOTA_FISCAL_CARGA
SQLSERVER_HOST=172.20.12.219
SQLSERVER_DATABASE=DFE
SQLSERVER_PORT=1433

# -------------------------------------------------------
# Destino do ETL
# -------------------------------------------------------
ETL_TARGET=postgres

# PostgreSQL local/desenvolvimento
DATABASE_URL=postgres://varadouro:varadouro_dev@localhost:5432/varadouro_digital
# Ou, separadamente:
PGHOST=localhost
PGPORT=5432
PGDATABASE=varadouro_digital
PGUSER=varadouro
PGPASSWORD=varadouro_dev
PGSSLMODE=disable

# Migração Supabase -> Postgres local
MIGRAR_TABELAS=dim_ente,dim_credor,fato_empenho
MIGRAR_MODO=truncate_insert
MIGRAR_BATCH_SIZE=1000

# -------------------------------------------------------
# Enriquecimento cadastral de credores — fonte interna SQL Server
# Execute: npm run credor:fontes:inspecionar  para descobrir os valores corretos.
# -------------------------------------------------------
CREDOR_INTERNO_DATABASE=APC
CREDOR_INTERNO_TABLE=
CREDOR_INTERNO_DOCUMENTO_COLUMN=
CREDOR_INTERNO_NOME_COLUMN=
CREDOR_INTERNO_TIPO_DOCUMENTO_COLUMN=
CREDOR_INTERNO_CIDADE_COLUMN=
CREDOR_INTERNO_UF_COLUMN=
CREDOR_INTERNO_EMAIL_COLUMN=
CREDOR_INTERNO_TELEFONE_COLUMN=

# -------------------------------------------------------
# SIOPS — Sistema de Informações sobre Orçamentos Públicos em Saúde
# API pública do Ministério da Saúde / OpenDataSUS
# Documentação: https://opendatasus.saude.gov.br
# Portal SIOPS: https://siops.datasus.gov.br
# -------------------------------------------------------
SIOPS_API_BASE_URL=https://siops-consulta-publica-api.saude.gov.br
SIOPS_UF_CODIGO=12
# SIOPS_UF_CODIGO: código IBGE numérico da UF (Acre=12, AM=13, PA=15, etc.)
SIOPS_ANO_INICIO=2022
SIOPS_ANO_FIM=2026
SIOPS_TIMEOUT_MS=30000
SIOPS_RATE_LIMIT_MS=500
# Nota: a API pública não exige credencial.
# Caso algum endpoint retorne 401/403, adicionar aqui após verificar documentação:
# SIOPS_API_TOKEN=

# -------------------------------------------------------
# Enriquecimento de CNPJ via API pública (opcional)
# CNPJ_ENRICH_PROVIDER: none | brasilapi | receitaws
# none = desativado (padrão seguro)
# -------------------------------------------------------
CNPJ_ENRICH_PROVIDER=none
CNPJ_ENRICH_RATE_LIMIT_MS=1000
CNPJ_ENRICH_MAX_PER_RUN=100

# -------------------------------------------------------
# CNES / UBS — Cadastro Nacional de Estabelecimentos de Saúde
# API REST pública: https://apidadosabertos.saude.gov.br/cnes
# Endpoint: /estabelecimentos?codigo_uf={uf}&limit={n}&offset={n}
# UBS: adicionar &codigo_tipo_unidade=02
# -------------------------------------------------------
CNES_API_BASE_URL=https://apidadosabertos.saude.gov.br/cnes
# CNES_UF: código IBGE numérico da UF (Acre=12, AM=13, etc.)
CNES_UF=12
CNES_TIMEOUT_MS=30000
CNES_RATE_LIMIT_MS=500
# Não é necessário configurar resource_id — a API REST é descoberta automaticamente.
CNES_RESOURCE_ID=
UBS_RESOURCE_ID=

# -------------------------------------------------------
# SICONFI/RREO — Relatório Resumido da Execução Orçamentária
# API DataLake Tesouro Nacional (pública, sem credenciais)
# Documentação: https://apidatalake.tesouro.gov.br/ords/siconfi/tt/rreo
# -------------------------------------------------------
SICONFI_API_BASE_URL=https://apidatalake.tesouro.gov.br/ords/siconfi/tt
SICONFI_CO_IBGE_UF=12
# SICONFI_CO_IBGE_UF: código IBGE da UF (Acre=12, AM=13, etc.)
SICONFI_ANO_INICIO=2021
SICONFI_ANO_FIM=2026
SICONFI_TIMEOUT_MS=30000
SICONFI_RATE_LIMIT_MS=1000
# Períodos bimestrais: 1=1ºBim, 2=2ºBim, ..., 6=6ºBim (ano completo)
SICONFI_PERIODOS=1,2,3,4,5,6

# -------------------------------------------------------
# SISAGUA — Qualidade da água / Vigilância sanitária
# API pública do Ministério da Saúde / OpenDataSUS
# Base: https://apidadosabertos.saude.gov.br/sisagua
# -------------------------------------------------------
SISAGUA_API_BASE_URL=https://apidadosabertos.saude.gov.br
SISAGUA_UF=AC
SISAGUA_ANO_INICIO=2024
SISAGUA_ANO_FIM=2026
SISAGUA_TIMEOUT_MS=30000
SISAGUA_RATE_LIMIT_MS=500

# Resources/endpoints opcionais, preenchidos após inspeção
SISAGUA_CONTROLE_MENSAL_RESOURCE_ID=
SISAGUA_VIGILANCIA_RESOURCE_ID=
SISAGUA_FORA_PADRAO_RESOURCE_ID=
SISAGUA_POPULACAO_ABASTECIDA_RESOURCE_ID=
