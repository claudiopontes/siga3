    "pni:direto:inspecionar": "ts-node jobs/pni-direto-inspecionar.ts",
    "pni:api:inspecionar": "ts-node jobs/pni-api-inspecionar.ts",
    "pni:ingest": "ts-node jobs/ingest-pni.ts",
    "mart:pni": "ts-node jobs/refresh-mart-pni.ts",
    "carga-pni:postgres": "npm run pni:ingest && npm run mart:pni && npm run mart:saude-consolidado",
    "carga-saude:postgres": "npm run carga-siops:postgres && npm run carga-cnes-ubs:postgres && npm run carga-sisagua:postgres && npm run carga-infodengue:postgres && npm run carga-pni:postgres"
