  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "pg": "^8.13.3",
    "dotenv": "^16.5.0",
    "msnodesqlv8": "^4.5.0",
    "mssql": "^11.0.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.5",
    "@types/pg": "^8.11.11",
    "@types/node": "^20.19.25",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
